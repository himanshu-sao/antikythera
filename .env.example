# Antikythera development environment configuration
# ------------------------------------------------
# Server port for the backend API (default 8006)
PORT=8006

# Frontend Vite dev server URL (used by backend to proxy static assets)
VITE_API_URL=http://localhost:5173

# Jira integration credentials – used when connecting to a Jira Cloud instance
# Base URL of your Jira instance (e.g., https://yourdomain.atlassian.net)
JIRA_BASE_URL=https://your-jira-instance.atlassian.net
# Personal Access Token for Jira API authentication. Create one in Jira Settings > API Tokens.
JIRA_PAT=your_jira_pat_here

# Optional GitHub token if you plan to use GitHub adapters (not required for current features)
# GITHUB_TOKEN=your_github_token_here
