# Antikythera Frontend (UI)
# Multi-stage build: Node builder + lightweight runtime

# ------------------------------------------------------------------------------
# Stage 1: Builder - Install dependencies and build
# ------------------------------------------------------------------------------
FROM node:20-alpine as builder

WORKDIR /app/ui

# Copy package files
COPY ui/package.json ui/package-lock.json* ./

# Install dependencies
RUN npm ci --legacy-peer-deps 2>/dev/null || npm install --legacy-peer-deps

# Copy source code
COPY ui/ ./

# Build the frontend
RUN npm run build

# ------------------------------------------------------------------------------
# Stage 2: Runtime - Serve with nginx (production) or vite (dev)
# ------------------------------------------------------------------------------
FROM node:20-alpine as runtime

WORKDIR /app/ui

# Copy package files for runtime dependencies
COPY ui/package.json ./

# Install only production dependencies if needed, but we'll use vite for dev
RUN npm install --legacy-peer-deps

# Copy built assets from builder
COPY --from=builder /app/ui/dist ./dist
COPY --from=builder /app/ui/node_modules ./node_modules
COPY --from=builder /app/ui/package.json ./

# Copy vite config (needed for dev server proxy)
COPY ui/vite.config.ts ./vite.config.ts
COPY ui/index.html ./index.html

# Copy entrypoint script
COPY docker/ui-entrypoint.sh /usr/local/bin/ui-entrypoint.sh
RUN chmod +x /usr/local/bin/ui-entrypoint.sh

# Expose Vite dev server port
EXPOSE 5173

# Entrypoint handles config validation and starts Vite
ENTRYPOINT ["/usr/local/bin/ui-entrypoint.sh"]

# Default: run Vite dev server
CMD ["dev", "--host", "0.0.0.0", "--port", "5173"]